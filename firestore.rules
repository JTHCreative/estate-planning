rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    // Users can read their partner's profile
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == userId
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        // Allow partner to update partnerId field during linking
        (request.auth.uid == resource.data.partnerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == userId)
      );
    }

    // Allow querying users collection — needed for household member lookups
    // (array-contains on householdIds) and for invite/partner-code lookups.
    match /users/{userId} {
      allow list: if request.auth != null;
    }

    // Households: any authenticated user can create one; members (and the
    // creator) can read and update. Listing is allowed so users can look up
    // a household by invite code when joining.
    match /households/{householdId} {
      allow get: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        householdId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdIds
      );
      allow list: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        householdId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdIds
      );
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // Institutions: owner and their partner can read; only owner can write
    match /institutions/{instId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == resource.data.userId
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == resource.data.userId
      );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow listing own institutions
      allow list: if request.auth != null;
    }

    // Accounts: same rules as institutions
    match /accounts/{acctId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == resource.data.userId
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == resource.data.userId
      );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null;
    }
  }
}
